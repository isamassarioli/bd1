<jasperReport name="loc004_2" language="java" columnCount="1" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="47cab148-5884-4ce4-bf1e-1ff2f521a0c0">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Loc004 Data Adapter"/>
	<query language="SQL"><![CDATA[SELECT
    EXTRACT(YEAR FROM l.dat_locacao) AS ano,
    EXTRACT(MONTH FROM l.dat_locacao) AS mes,
    c.nom_cliente,
    SUM(l.val_locacao) AS valor_devido
FROM locacao l
INNER JOIN cliente c
    ON c.cod_cliente = l.cod_cliente
WHERE l.dat_devolucao IS NULL
GROUP BY
    ano,
    mes,
    c.nom_cliente
ORDER BY
    ano,
    mes,
    c.nom_cliente]]></query>
	<field name="mes" class="java.math.BigDecimal">
