<jasperReport name="loc004_1" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="19520da6-f1de-4e8a-8884-53886d5b3c8c">
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Loc004 Data Adapter"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<query language="sql"><![CDATA[SELECT
    c.cod_cliente,
    c.nom_cliente,
    f.cod_fita,
    fi.nom_filme,
    l.val_locacao,
    sum(l.val_locacao) as total_locacao
FROM locacao l
INNER JOIN cliente c
    ON c.cod_cliente = l.cod_cliente
INNER JOIN fita f
    ON f.cod_fita = l.cod_fita
INNER JOIN filme fi
    ON fi.cod_filme = f.cod_filme
WHERE l.dat_devolucao IS NULL
GROUP BY c.cod_cliente,
    c.nom_cliente,
    f.cod_fita,
    fi.nom_filme,
    l.val_locacao
ORDER BY
    c.nom_cliente,
    fi.nom_filme;]]></query>
