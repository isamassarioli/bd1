<jasperReport name="loc004_3" language="java" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="47cab148-5884-4ce4-bf1e-1ff2f521a0c0">
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Loc004 Data Adapter"/>
	<parameter name="mesInicial" class="java.lang.Integer"/>
	<parameter name="mesFinal" class="java.lang.Integer"/>
	<parameter name="anoInicial" class="java.lang.Integer"/>
	<parameter name="anoFinal" class="java.lang.Integer"/>
	<query language="SQL"><![CDATA[SELECT 
    EXTRACT(YEAR FROM l.dat_devolucao) AS ano, 
    EXTRACT(MONTH FROM l.dat_devolucao) AS mes, 
    TO_CHAR(SUM(l.val_locacao), 'LFM999G999D99') AS valor_arrecadado 
FROM 
    locacao l 
WHERE 
    l.dat_devolucao IS NOT NULL 
    AND (
        EXTRACT(YEAR FROM l.dat_devolucao)::INT * 100 
        + EXTRACT(MONTH FROM l.dat_devolucao)::INT
    ) BETWEEN (
        CAST($P{anoInicial} AS INTEGER) * 100 
        + CAST($P{mesInicial} AS INTEGER)
    ) AND (
        CAST($P{anoFinal} AS INTEGER) * 100 
        + CAST($P{mesFinal} AS INTEGER)
    ) 
GROUP BY 
    EXTRACT(YEAR FROM l.dat_devolucao), 
    EXTRACT(MONTH FROM l.dat_devolucao) 
ORDER BY 
    ano, 
    mes;
]]></query>
	<field name="ano" class="java.math.BigDecimal">
		<property name="com.jaspersoft.studio.field.name" value="ano"/>
		<property name="com.jaspersoft.studio.field.label" value="ano"/>
	</field>
