<jasperReport name="loc004_4" language="java" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="a75348ba-94b8-4b9e-a502-42b5a6ad9982">
	<property name="ireport.zoom" value="0.9090909090909091"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<property name="com.jaspersoft.studio.data.defaultdataadapter" value="Loc004 Data Adapter"/>
	<property name="com.jaspersoft.studio.data.sql.tables" value=""/>
	<parameter name="codigoCliente" class="java.lang.Integer"/>
	<query language="sql"><![CDATA[SELECT
    c.cod_cliente,
    c.nom_cliente,
    c.cod_cliente_titular,
    
    CASE
    WHEN c.cod_cliente_titular IS NULL
    THEN 'Titular'
    ELSE 'Dependente'
	END AS tipo_cliente,

    COALESCE(SUM(l.val_locacao),0) AS total_gasto,

    COALESCE(
        SUM(
            CASE
                WHEN l.dat_devolucao IS NULL
                THEN l.val_locacao
                ELSE 0
            END
        ),0
    ) AS valor_pendente

FROM cliente c

LEFT JOIN locacao l
ON l.cod_cliente = c.cod_cliente

WHERE
    c.cod_cliente = $P{codigoCliente}
    OR c.cod_cliente_titular = $P{codigoCliente}

GROUP BY
    c.cod_cliente,
    c.nom_cliente,
    c.cod_cliente_titular

ORDER BY
    c.cod_cliente_titular NULLS FIRST,
    c.nom_cliente;]]></query>
